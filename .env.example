# Client Supabase configuration. Safe for browser use when paired with RLS.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional admin API override for local or cross-origin testing.
VITE_ADMIN_API_BASE_URL=

# Client-side admin gate. Server checks still happen in Netlify Functions.
VITE_ADMIN_ALLOWED_EMAILS=

# Server-side Supabase configuration for Netlify Functions and scripts.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secrets for ingestion and admin APIs. Keep server-only.
INGEST_SHARED_SECRET=
ADMIN_SHARED_SECRET=
ADMIN_ALLOWED_EMAILS=

# Used by Supabase CLI workflows.
SUPABASE_ACCESS_TOKEN=

# Optional: show pending partner content in the client during local review.
VITE_SHOW_PENDING_PARTNER_CONTENT=
