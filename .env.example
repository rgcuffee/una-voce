# Client Supabase configuration. Safe for browser use when paired with RLS.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional admin API override for local or cross-origin testing.
VITE_ADMIN_API_BASE_URL=

# Client-side admin gate. Server checks still happen in Netlify Functions.
VITE_ADMIN_ALLOWED_EMAILS=

# Server-side Supabase configuration for Netlify Functions and scripts.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secrets for ingestion and admin APIs. Keep server-only.
INGEST_SHARED_SECRET=
ADMIN_SHARED_SECRET=
ADMIN_ALLOWED_EMAILS=

# Used by Supabase CLI workflows.
SUPABASE_ACCESS_TOKEN=

# Optional: show pending partner content in the client during local review.
VITE_SHOW_PENDING_PARTNER_CONTENT=

# Zoom Meeting SDK / OAuth experimental room. These values are server-only.
# Set the OAuth redirect URI in Zoom to https://your-domain/api/zoom/oauth/callback
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_SESSION_SECRET=
ZOOM_OAUTH_REDIRECT_URI=http://localhost:8888/api/zoom/oauth/callback

# One controlled experimental room. Do not expose the SDK client secret in Vite variables.
ZOOM_TEST_ROOM_NAME=Compline together
ZOOM_TEST_ROOM_DESCRIPTION=A quiet, hosted room for praying Night Prayer together.
ZOOM_TEST_ROOM_STATUS=scheduled
ZOOM_TEST_ROOM_START_AT=
ZOOM_TEST_ROOM_MEETING_NUMBER=
ZOOM_TEST_ROOM_PASSWORD=
# When true, joining requires a connected Zoom account and asks Zoom for a short-lived ZAK.
ZOOM_TEST_ROOM_REQUIRES_AUTH=false
